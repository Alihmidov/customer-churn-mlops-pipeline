# Virtual environments
.venv/
venv/
ENV/

# Python cache files
**/__pycache__/
*.py[cod]
*$py.class

# Docker and logs
.dockerignore
logs/
*.log

# Git and IDE settings
.git/
.vscode/
.idea/

# Temporary and system files
.DS_Store
Thumbs.db